<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2F5">

    <!-- ================================================================
         MAIN CONTENT
         paddingTop：避开顶部摄像头/状态栏，按实际设备调整
         paddingBottom：避开底部导航栏，按实际设备调整
         ================================================================ -->
    <LinearLayout
        android:id="@+id/layout_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingTop="36dp"
        android:paddingBottom="52dp"
        android:background="#F0F2F5"
        android:visibility="invisible">

        <!-- ── Title Bar ── -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="#1A237E"
            android:paddingLeft="4dp"
            android:paddingRight="16dp">

            <Button
                android:id="@+id/btn_back"
                android:layout_width="56dp"
                android:layout_height="match_parent"
                android:layout_alignParentLeft="true"
                android:layout_centerVertical="true"
                android:background="@android:color/transparent"
                android:text="&lt;"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="PAYMENT"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"/>

        </RelativeLayout>

        <!-- ── Card Type Section ── -->
<!--        <LinearLayout-->
<!--            android:layout_width="match_parent"-->
<!--            android:layout_height="wrap_content"-->
<!--            android:orientation="vertical"-->
<!--            android:background="#FFFFFF"-->
<!--            android:paddingLeft="16dp"-->
<!--            android:paddingRight="16dp"-->
<!--            android:paddingTop="8dp"-->
<!--            android:paddingBottom="8dp"-->
<!--            android:layout_marginTop="2dp">-->

<!--            <TextView-->
<!--                android:layout_width="wrap_content"-->
<!--                android:layout_height="wrap_content"-->
<!--                android:text="CARD TYPE  /  交易类型"-->
<!--                android:textColor="#9E9E9E"-->
<!--                android:textSize="11sp"-->
<!--                android:textStyle="bold"/>-->

<!--            <Spinner-->
<!--                android:id="@+id/spinner_card_type"-->
<!--                android:layout_width="match_parent"-->
<!--                android:layout_height="40dp"-->
<!--                android:layout_marginTop="2dp"/>-->

<!--        </LinearLayout>-->

        <!-- ── Amount Display Section ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:layout_marginTop="2dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AMOUNT  /  交易金额 (CNY)"
                android:textColor="#9E9E9E"
                android:textSize="11sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tv_amount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#1A237E"
                android:textSize="46sp"
                android:textStyle="bold"
                android:typeface="monospace"
                android:layout_marginTop="4dp"/>

        </LinearLayout>

        <!-- ── Numeric Keypad ── -->
        <!-- 每行固定 52dp，共 4 行，整体高度不再撑满剩余空间 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#F0F2F5"
            android:layout_marginTop="2dp"
            android:paddingLeft="6dp"
            android:paddingRight="6dp"
            android:paddingTop="6dp"
            android:paddingBottom="2dp">

            <TextView
                android:id="@+id/tv_message1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#1A237E"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:padding="4dp"
                android:text="" />

            <TextView
                android:id="@+id/tv_message2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#666666"
                android:textSize="12sp"
                android:layout_marginTop="4dp"
                android:padding="4dp"
                android:text="" />

            <!-- Row 1: 7  8  9 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp">

                <Button
                    android:id="@+id/btn_7"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginRight="4dp"
                    android:text="7"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#212121"
                    android:background="@drawable/btn_numpad"/>

                <Button
                    android:id="@+id/btn_8"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginRight="4dp"
                    android:text="8"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#212121"
                    android:background="@drawable/btn_numpad"/>

                <Button
                    android:id="@+id/btn_9"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="9"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#212121"
                    android:background="@drawable/btn_numpad"/>

            </LinearLayout>

            <!-- Row 2: 4  5  6 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp">

                <Button
                    android:id="@+id/btn_4"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginRight="4dp"
                    android:text="4"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#212121"
                    android:background="@drawable/btn_numpad"/>

                <Button
                    android:id="@+id/btn_5"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginRight="4dp"
                    android:text="5"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#212121"
                    android:background="@drawable/btn_numpad"/>

                <Button
                    android:id="@+id/btn_6"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="6"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#212121"
                    android:background="@drawable/btn_numpad"/>

            </LinearLayout>

            <!-- Row 3: 1  2  3 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp">

                <Button
                    android:id="@+id/btn_1"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginRight="4dp"
                    android:text="1"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#212121"
                    android:background="@drawable/btn_numpad"/>

                <Button
                    android:id="@+id/btn_2"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginRight="4dp"
                    android:text="2"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#212121"
                    android:background="@drawable/btn_numpad"/>

                <Button
                    android:id="@+id/btn_3"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="3"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#212121"
                    android:background="@drawable/btn_numpad"/>

            </LinearLayout>

            <!-- Row 4: .  0  DEL -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_dot"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginRight="4dp"
                    android:text="."
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="#212121"
                    android:background="@drawable/btn_numpad"/>

                <Button
                    android:id="@+id/btn_0"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginRight="4dp"
                    android:text="0"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#212121"
                    android:background="@drawable/btn_numpad"/>

                <Button
                    android:id="@+id/btn_del"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="DEL"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#E53935"
                    android:background="@drawable/btn_numpad"/>

            </LinearLayout>

        </LinearLayout>

        <!-- 弹性空白：吸收剩余空间，使按钮始终贴底 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <!-- ── Action Buttons ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:orientation="horizontal"
            android:layout_marginTop="2dp">

            <Button
                android:id="@+id/btn_cancel"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="取消  CANCEL"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:background="#E53935"/>

            <Button
                android:id="@+id/btn_confirm"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="确认  CONFIRM"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:background="#43A047"/>



        </LinearLayout>

    </LinearLayout>
    <!-- ================================================================
         LOADING OVERLAY — 全屏遮罩，无安全区限制
         ================================================================ -->
    <FrameLayout
        android:id="@+id/layout_loading"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC0D1129"
        android:visibility="visible">

        <LinearLayout
            android:layout_width="220dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#FFFFFF"
            android:paddingLeft="32dp"
            android:paddingRight="32dp"
            android:paddingTop="28dp"
            android:paddingBottom="28dp">

            <ProgressBar
                android:id="@+id/progress_bar"
                style="?android:attr/progressBarStyle"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:indeterminate="true"/>

            <TextView
                android:id="@+id/tv_loading_msg"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Initializing..."
                android:textColor="#424242"
                android:textSize="14sp"
                android:gravity="center"/>

        </LinearLayout>

    </FrameLayout>

</FrameLayout>
