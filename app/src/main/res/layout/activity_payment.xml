    <!--            <Spinner-->
    <!--                android:id="@+id/spinner_card_type"-->
    <!--                android:layout_width="match_parent"-->
    <!--                android:layout_height="40dp"-->
    <!--                android:layout_marginTop="2dp"/>-->
    <!--        </LinearLayout>-->
    <!-- 鈹€鈹€ Amount Display Section 鈹€鈹€ -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="#FFFFFF" android:paddingLeft="16dp" android:paddingRight="16dp" android:paddingTop="10dp" android:paddingBottom="10dp" android:layout_marginTop="2dp" android:gravity="center">
      <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/payment_amount_label" android:textColor="#9E9E9E" android:textSize="11sp" android:textStyle="bold" />
      <TextView android:id="@+id/tv_amount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#1A237E" android:textSize="46sp" android:textStyle="bold" android:typeface="monospace" android:layout_marginTop="4dp" />
    </LinearLayout>
    <!-- 鈹€鈹€ Numeric Keypad 鈹€鈹€ -->
    <!-- 姣忚鍥哄畾 52dp锛屽叡 4 琛岋紝鏁翠綋楂樺害涓嶅啀鎾戞弧鍓╀綑绌洪棿 -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="#F0F2F5" android:layout_marginTop="2dp" android:paddingLeft="6dp" android:paddingRight="6dp" android:paddingTop="6dp" android:paddingBottom="2dp">
      <TextView android:id="@+id/tv_message1" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#1A237E" android:textSize="14sp" android:textStyle="bold" android:layout_marginTop="16dp" android:padding="4dp" android:text="" />
      <TextView android:id="@+id/tv_message2" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#666666" android:textSize="12sp" android:layout_marginTop="4dp" android:padding="4dp" android:text="" />
      <!-- Row 1: 7  8  9 -->
      <LinearLayout android:layout_width="match_parent" android:layout_height="52dp" android:orientation="horizontal" android:layout_marginBottom="4dp">
        <Button android:id="@+id/btn_7" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginRight="4dp" android:text="7" android:textSize="22sp" android:textStyle="bold" android:textColor="#212121" android:background="@drawable/btn_numpad" />
        <Button android:id="@+id/btn_8" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginRight="4dp" android:text="8" android:textSize="22sp" android:textStyle="bold" android:textColor="#212121" android:background="@drawable/btn_numpad" />
        <Button android:id="@+id/btn_9" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="9" android:textSize="22sp" android:textStyle="bold" android:textColor="#212121" android:background="@drawable/btn_numpad" />
      </LinearLayout>
      <!-- Row 2: 4  5  6 -->
      <LinearLayout android:layout_width="match_parent" android:layout_height="52dp" android:orientation="horizontal" android:layout_marginBottom="4dp">
        <Button android:id="@+id/btn_4" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginRight="4dp" android:text="4" android:textSize="22sp" android:textStyle="bold" android:textColor="#212121" android:background="@drawable/btn_numpad" />
        <Button android:id="@+id/btn_5" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginRight="4dp" android:text="5" android:textSize="22sp" android:textStyle="bold" android:textColor="#212121" android:background="@drawable/btn_numpad" />
        <Button android:id="@+id/btn_6" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="6" android:textSize="22sp" android:textStyle="bold" android:textColor="#212121" android:background="@drawable/btn_numpad" />
      </LinearLayout>
      <!-- Row 3: 1  2  3 -->
      <LinearLayout android:layout_width="match_parent" android:layout_height="52dp" android:orientation="horizontal" android:layout_marginBottom="4dp">
        <Button android:id="@+id/btn_1" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginRight="4dp" android:text="1" android:textSize="22sp" android:textStyle="bold" android:textColor="#212121" android:background="@drawable/btn_numpad" />
        <Button android:id="@+id/btn_2" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginRight="4dp" android:text="2" android:textSize="22sp" android:textStyle="bold" android:textColor="#212121" android:background="@drawable/btn_numpad" />
        <Button android:id="@+id/btn_3" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="3" android:textSize="22sp" android:textStyle="bold" android:textColor="#212121" android:background="@drawable/btn_numpad" />
      </LinearLayout>
      <!-- Row 4: .  0  DEL -->
      <LinearLayout android:layout_width="match_parent" android:layout_height="52dp" android:orientation="horizontal">
        <Button android:id="@+id/btn_dot" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginRight="4dp" android:text="." android:textSize="26sp" android:textStyle="bold" android:textColor="#212121" android:background="@drawable/btn_numpad" />
        <Button android:id="@+id/btn_0" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginRight="4dp" android:text="0" android:textSize="22sp" android:textStyle="bold" android:textColor="#212121" android:background="@drawable/btn_numpad" />
        <Button android:id="@+id/btn_del" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="@string/payment_delete" android:textSize="14sp" android:textStyle="bold" android:textColor="#E53935" android:background="@drawable/btn_numpad" />
      </LinearLayout>
    </LinearLayout>
    <!-- 寮规€х┖鐧斤細鍚告敹鍓╀綑绌洪棿锛屼娇鎸夐挳濮嬬粓璐村簳 -->
    <View android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" />
    <!-- 鈹€鈹€ Action Buttons 鈹€鈹€ -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="58dp" android:orientation="horizontal" android:layout_marginTop="2dp">
      <Button android:id="@+id/btn_cancel" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="@string/payment_cancel" android:textColor="#FFFFFF" android:textSize="15sp" android:textStyle="bold" android:background="#E53935" />
      <Button android:id="@+id/btn_confirm" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="@string/payment_confirm" android:textColor="#FFFFFF" android:textSize="15sp" android:textStyle="bold" android:background="#43A047" />
    </LinearLayout>
  </LinearLayout>
  <!-- ================================================================
         LOADING OVERLAY 鈥?鍏ㄥ睆閬僵锛屾棤瀹夊叏鍖洪檺鍒?
         ================================================================ -->
  <FrameLayout android:id="@+id/layout_loading" android:layout_width="match_parent" android:layout_height="match_parent" android:background="#CC0D1129" android:visibility="visible">
    <LinearLayout android:layout_width="220dp" android:layout_height="wrap_content" android:layout_gravity="center" android:orientation="vertical" android:gravity="center" android:background="#FFFFFF" android:paddingLeft="32dp" android:paddingRight="32dp" android:paddingTop="28dp" android:paddingBottom="28dp">
      <ProgressBar android:id="@+id/progress_bar" style="?android:attr/progressBarStyle" android:layout_width="48dp" android:layout_height="48dp" android:indeterminate="true" />
      <TextView android:id="@+id/tv_loading_msg" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="14dp" android:text="@string/payment_loading_initializing" android:textColor="#424242" android:textSize="14sp" android:gravity="center" />
    </LinearLayout>
  </FrameLayout>
</FrameLayout>